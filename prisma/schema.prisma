generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String
  role           String   @default("user")
  status         String   @default("pending")
  theme          String   @default("default")
  emailVerified  Boolean  @default(false)
  verifyToken    String?  @unique
  resetToken     String?  @unique
  resetTokenExp  DateTime?
  moxfieldUsername String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  decks              Deck[]
  gameEntries        GamePlayer[]
  playgroupMembers   PlaygroupMember[]
  sentInvites        PlaygroupInvite[]  @relation("InviteSender")
}

model Playgroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members PlaygroupMember[]
  games   Game[]
  invites PlaygroupInvite[]
}

model PlaygroupMember {
  id        String   @id @default(cuid())
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  playgroupId String
  playgroup   Playgroup @relation(fields: [playgroupId], references: [id], onDelete: Cascade)

  @@unique([userId, playgroupId])
  @@index([playgroupId])
}

model PlaygroupInvite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  email     String?
  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  playgroupId String
  playgroup   Playgroup @relation(fields: [playgroupId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([playgroupId])
  @@index([token])
}

model Deck {
  id             String   @id @default(cuid())
  name           String
  commander      String
  commanderImage String?
  commander2      String?
  commander2Image String?
  bracket        Int?
  edhp           Float?
  decklist       String?
  lastPlayedAt DateTime?
  colorW    Boolean  @default(false)
  colorU    Boolean  @default(false)
  colorB    Boolean  @default(false)
  colorR    Boolean  @default(false)
  colorG    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameEntries GamePlayer[]

  @@index([userId])
}

model Game {
  id        String   @id @default(cuid())
  playedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  notes     String?
  asterisk  Boolean  @default(false)

  playgroupId String?
  playgroup   Playgroup? @relation(fields: [playgroupId], references: [id], onDelete: SetNull)

  players GamePlayer[]

  @@index([playgroupId])
}

model CardCache {
  name      String   @id
  data      String
  fetchedAt DateTime @default(now())
}

model GamePlayer {
  id       String  @id @default(cuid())
  isWinner Boolean @default(false)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([userId])
  @@index([deckId])
}

# Database — Vercel Postgres (Neon) connection string
# Get this from Vercel Dashboard > Storage > your database > .env.local tab
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Moxfield API (keep secret — never expose to client)
MOXFIELD_USER_AGENT="your-moxfield-user-agent-key"
